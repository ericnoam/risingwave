    {"id":"file:src/compute/src/rpc/service/config_service.rs","type":"file","name":"config_service.rs","filePath":"src/compute/src/rpc/service/config_service.rs","summary":"Implements the gRPC ConfigService allowing the meta node to push configuration updates to the compute node at runtime.","tags":["api-handler","service","rpc","configuration"],"complexity":"moderate"},
