{
  "nodes": [
    {"id":"file:src/utils/pgwire/src/error.rs","type":"file","name":"error.rs","filePath":"src/utils/pgwire/src/error.rs","summary":"Defines PsqlError, the top-level error type for the pgwire protocol layer, wrapping SQL and transport-level failures for PostgreSQL wire protocol clients.","tags":["error-handling","data-model"],"complexity":"simple"},
    {"id":"file:src/utils/pgwire/src/error_or_notice.rs","type":"file","name":"error_or_notice.rs","filePath":"src/utils/pgwire/src/error_or_notice.rs","summary":"Defines ErrorOrNotice, a tagged union for PostgreSQL error and notice response messages with severity, SQLSTATE code, and message fields.","tags":["data-model","serialization"],"complexity":"simple"},
    {"id":"file:src/utils/pgwire/src/ldap_auth.rs","type":"file","name":"ldap_auth.rs","filePath":"src/utils/pgwire/src/ldap_auth.rs","summary":"Implements LDAP-based user authentication for the PostgreSQL wire protocol, supporting simple and search+bind modes using the ldap3 client.","tags":["service","middleware","security"],"complexity":"complex"},
    {"id":"file:src/utils/pgwire/src/lib.rs","type":"file","name":"lib.rs","filePath":"src/utils/pgwire/src/lib.rs","summary":"Crate root for risingwave_pgwire; re-exports the full PostgreSQL wire protocol implementation including protocol, server, and message types.","tags":["entry-point","barrel"],"complexity":"simple"},
    {"id":"file:src/utils/pgwire/src/memory_manager.rs","type":"file","name":"memory_manager.rs","filePath":"src/utils/pgwire/src/memory_manager.rs","summary":"Tracks in-flight query memory usage in the pgwire layer, triggering backpressure notifications when query memory budget is exceeded.","tags":["service","middleware"],"complexity":"simple"},
    {"id":"file:src/utils/pgwire/src/net.rs","type":"file","name":"net.rs","filePath":"src/utils/pgwire/src/net.rs","summary":"Provides network abstraction for pgwire connections, wrapping plain TCP and TLS streams behind a unified async I/O interface.","tags":["utility","middleware"],"complexity":"simple"},
    {"id":"file:src/utils/pgwire/src/pg_extended.rs","type":"file","name":"pg_extended.rs","filePath":"src/utils/pgwire/src/pg_extended.rs","summary":"Implements the PostgreSQL extended query protocol state machine: Parse, Bind, Execute, Describe, and Close message handling.","tags":["api-handler","middleware","sql"],"complexity":"moderate"},
    {"id":"file:src/utils/pgwire/src/pg_field_descriptor.rs","type":"file","name":"pg_field_descriptor.rs","filePath":"src/utils/pgwire/src/pg_field_descriptor.rs","summary":"Defines PgFieldDescriptor for describing result-set column metadata (name, OID, type modifier) in PostgreSQL RowDescription messages.","tags":["data-model","serialization"],"complexity":"simple"},
    {"id":"file:src/utils/pgwire/src/pg_message.rs","type":"file","name":"pg_message.rs","filePath":"src/utils/pgwire/src/pg_message.rs","summary":"Implements all PostgreSQL frontend and backend message types with binary serialization/deserialization for the Postgres wire protocol (v3).","tags":["data-model","serialization","middleware"],"complexity":"complex"},
    {"id":"file:src/utils/pgwire/src/pg_protocol.rs","type":"file","name":"pg_protocol.rs","filePath":"src/utils/pgwire/src/pg_protocol.rs","summary":"Core PostgreSQL wire protocol state machine that reads frontend messages, dispatches to the session handler, and writes backend responses.","tags":["middleware","api-handler","sql"],"complexity":"complex"},
    {"id":"file:src/utils/pgwire/src/pg_response.rs","type":"file","name":"pg_response.rs","filePath":"src/utils/pgwire/src/pg_response.rs","summary":"Defines PgResponse, a streaming container for SQL execution results carrying command tag, row schema, and async row data chunks.","tags":["data-model","middleware"],"complexity":"complex"},
    {"id":"file:src/utils/pgwire/src/pg_server.rs","type":"file","name":"pg_server.rs","filePath":"src/utils/pgwire/src/pg_server.rs","summary":"Defines the SessionManager and Session traits that production SQL engines implement, and provides the TCP/TLS server loop for pgwire connections.","tags":["entry-point","service","middleware"],"complexity":"complex"},
    {"id":"file:src/utils/pgwire/src/types.rs","type":"file","name":"types.rs","filePath":"src/utils/pgwire/src/types.rs","summary":"Defines pgwire type conversion helpers mapping RisingWave scalar types to PostgreSQL OIDs and binary/text encoding for wire transmission.","tags":["data-model","serialization","utility"],"complexity":"moderate"},
